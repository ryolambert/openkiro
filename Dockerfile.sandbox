# syntax=docker/dockerfile:1
# Dockerfile.sandbox — ephemeral agent sandbox image
#
# This image is used as the target for Docker sandbox microVMs created by
# internal/sandbox. Each container instance runs with:
#   • Non-root user (sandbox UID 1000)
#   • Read-only root filesystem (--read-only)
#   • No network access (--network none)
#   • Dropped Linux capabilities (--cap-drop ALL)
#   • No new privileges (--security-opt no-new-privileges)
#   • Host workspace bind-mounted at /workspace
#
# Pre-installed agent tools:
#   • openkiro — Anthropic API proxy (built from source)
#   • rtk      — token compression toolkit (install when published)
#   • icm      — in-context memory MCP server (install when published)
#   • headroom — context budget manager (install when published)
#   • MCP gateway tools (discovered via Docker labels at runtime)
#
# Build:
#   docker build -f Dockerfile.sandbox -t openkiro-sandbox:latest .
#
# The sandbox manager (internal/sandbox) creates containers from this image
# automatically; you do not need to run it directly.

# ── Stage 1: build openkiro ─────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .

ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILD_DATE=unknown

RUN CGO_ENABLED=0 GOOS=linux go build \
      -trimpath \
      -ldflags="-s -w \
        -X main.version=${VERSION} \
        -X main.commit=${COMMIT} \
        -X main.date=${BUILD_DATE}" \
      -o /openkiro \
      ./cmd/openkiro

# ── Stage 2: agent sandbox runtime ─────────────────────────────────────────
FROM alpine:3.20

# Install runtime dependencies: ca-certs (for HTTPS), tini (PID 1 reaper).
RUN apk add --no-cache ca-certificates tini

# Create a non-root sandbox user (UID/GID 1000).
RUN addgroup -g 1000 sandbox && \
    adduser  -u 1000 -G sandbox -s /bin/sh -D sandbox

# Workspace directory — the sandbox manager bind-mounts host paths here.
RUN mkdir -p /workspace && chown sandbox:sandbox /workspace

# ── Install agent tools ──────────────────────────────────────────────────────
# TODO: Uncomment and replace with real install commands once packages are published.
#
# rtk — token compression toolkit
# RUN go install github.com/ryolambert/rtk@latest
#
# icm — in-context memory MCP server
# RUN go install github.com/ryolambert/icm@latest
#
# headroom — context budget manager
# RUN go install github.com/ryolambert/headroom@latest
#
# MCP gateway CLI (optional — the Go gateway package handles discovery)
# RUN go install github.com/ryolambert/mcp-gateway@latest

# Copy the openkiro binary built in stage 1.
COPY --from=builder /openkiro /usr/local/bin/openkiro

# Copy the secure entrypoint script.
COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Switch to the non-root sandbox user for all subsequent operations.
USER sandbox

# /workspace is the canonical working directory inside the sandbox.
WORKDIR /workspace

# tini is the init process; the entrypoint wraps the actual command.
ENTRYPOINT ["/sbin/tini", "--", "/entrypoint.sh"]
CMD ["openkiro", "server"]
